tint_cpp_args = [
  '-DTINT_BUILD_GLSL_WRITER=0',
  '-DTINT_BUILD_HLSL_WRITER=0',
  '-DTINT_BUILD_MSL_WRITER=0',
  '-DTINT_BUILD_NULL_WRITER=0',
  '-DTINT_BUILD_SPV_READER=1',
  '-DTINT_BUILD_SPV_WRITER=0',
  '-DTINT_BUILD_WGSL_READER=0',
  '-DTINT_BUILD_WGSL_WRITER=1',
  '-DTINT_ENABLE_IR_VALIDATION=0',
]

if host_machine.system() == 'windows'
  tint_cpp_args += [
    '-DTINT_BUILD_IS_LINUX=0',
    '-DTINT_BUILD_IS_MAC=0',
    '-DTINT_BUILD_IS_WIN=1',
  ]
elif host_machine.system() == 'darwin'
  tint_cpp_args += [
    '-DTINT_BUILD_IS_LINUX=0',
    '-DTINT_BUILD_IS_MAC=1',
    '-DTINT_BUILD_IS_WIN=0',
  ]
else
  tint_cpp_args += [
    '-DTINT_BUILD_IS_LINUX=1',
    '-DTINT_BUILD_IS_MAC=0',
    '-DTINT_BUILD_IS_WIN=0',
  ]
endif

tint_lib = static_library('tint', tint_sources,
  cpp_args: tint_cpp_args,
  include_directories: [
    include_directories('../dawn'),
    include_directories('../dawn/src/tint'),
    include_directories('../spirv-tools'),
    include_directories('../spirv-tools/include'),
    include_directories('../spirv-tools/include/generated'),
    include_directories('../spirv-headers/include'),
  ],
  override_options: ['cpp_std=c++20'],
)

tint_dep = declare_dependency(
  link_with: tint_lib,
  include_directories: [
    include_directories('../dawn'),
    include_directories('../dawn/src/tint'),
  ],
)
